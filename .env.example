# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# SQLite path. Must point at the mounted volume in production.
DB_PATH=/data/bookings.sqlite

# ── Telegram manager bot ───────────────────────────────────────────
# Leave both empty to disable the bot entirely.
# Get token from @BotFather. Get your Telegram user ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_IDS=

# ── Resend (booking confirmation emails) ───────────────────────────
# Emails fire on the manager's ✅ Potwierdź tap in Telegram, not on submit.
# Leave RESEND_API_KEY blank to disable the mailer entirely (the booking
# flow still works, just no email goes out).
#
# Setup:
# 1. Create an API key at https://resend.com/api-keys
# 2. Verify a sending domain (recommended subdomain: mail.offcutszczecin.pl)
#    with SPF + DKIM DNS records, then set MAIL_FROM to a sender on it.
# 3. Until the domain is verified, MAIL_FROM can use "Off Cut <onboarding@resend.dev>"
#    but Resend will only deliver to the team owner address.
RESEND_API_KEY=
MAIL_FROM=Off Cut <rezerwacje@mail.offcutszczecin.pl>
MAIL_REPLY_TO=offcutszczecin@gmail.com
# Set MAIL_DRY_RUN=1 in staging to log what would be sent without calling Resend.
MAIL_DRY_RUN=

# ── Google Tag Manager (frontend analytics) ────────────────────────
# GTM container ID, e.g. GTM-K4CZZ5XR. Vite bakes this into the build at
# `npm run build` time via the %VITE_GTM_ID% placeholder in index.html.
# Leave empty in local dev to disable GTM entirely (no script loads).
# In Docker/Dokploy this MUST be passed as a build-arg, not just a runtime
# env, because the static bundle is produced at image-build time.
VITE_GTM_ID=
