# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# SQLite path. Must point at the mounted volume in production.
DB_PATH=/data/bookings.sqlite

# ── Telegram manager bot ───────────────────────────────────────────
# Leave both empty to disable the bot entirely.
# Get token from @BotFather. Get your Telegram user ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_IDS=
