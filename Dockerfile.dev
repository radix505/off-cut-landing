FROM node:20-bookworm-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted at runtime by docker-compose.dev.yml.
# node_modules is masked by a named volume so the host tree never overrides
# what was installed against this container's platform.

EXPOSE 5173 3001

CMD ["npm", "run", "dev:all"]
